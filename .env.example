# =============================================================
# FollowMe.direct Cloudflare Worker — Environment Variables
# =============================================================
#
# HOW TO USE:
#   - PUBLIC vars: copy to wrangler.toml under [vars]
#   - SECRETS: set via CLI (never commit actual values!)
#       wrangler secret put CF_STREAM_TOKEN
#       wrangler secret put R2_ACCESS_KEY_ID
#       wrangler secret put R2_SECRET_ACCESS_KEY
#
# =============================================================

# ───────────────────────────────────────────────────────────────
# SECRETS — NEVER COMMIT ACTUAL VALUES
# Set via: wrangler secret put <NAME>
# ───────────────────────────────────────────────────────────────

# Cloudflare Stream API token (from dash.cloudflare.com > API Tokens)
# Permissions: Stream:Edit
CF_STREAM_TOKEN=your_stream_api_token_here

# R2 API credentials (from R2 > Manage API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key


# ───────────────────────────────────────────────────────────────
# PUBLIC ENV — Safe to store in wrangler.toml [vars]
# Also reference these in wrangler.toml — values below for docs only
# ───────────────────────────────────────────────────────────────

# Cloudflare Account ID (from dash.cloudflare.com — right sidebar)
CF_ACCOUNT_ID=your_cloudflare_account_id

# R2 bucket name
R2_BUCKET_NAME=followme-media

# CDN base URL (R2 custom domain)
CDN_BASE_URL=https://cdn.followme.direct

# Environment label
ENVIRONMENT=production
